#!/usr/bin/env bash
# e2e-configure [--show] [--path] [--set KEY VALUE] [--unset KEY]
# Creates and updates ~/.config/e2e-pr-assets/config (or $XDG_CONFIG_HOME equivalent).

set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -h "$source" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="${dir}/${source}"
  done
  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"

# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../lib/config.sh"

usage() {
  cat <<'EOF'
Usage:
  e2e-configure
  e2e-configure --show
  e2e-configure --path
  e2e-configure --set KEY VALUE
  e2e-configure --unset KEY

Environment variables still override values in the config file for one-off runs.
EOF
}

config_value_for_key() {
  local lookup_key="$1"
  local config_file="$2"
  local value=""

  if [[ ! -f "$config_file" ]]; then
    return 1
  fi

  set +e
  value="$(
    CONFIG_FILE="$config_file" CONFIG_KEY="$lookup_key" bash <<'EOF'
set -euo pipefail

# shellcheck source=/dev/null
source "$CONFIG_FILE"

if [[ -z "${!CONFIG_KEY+x}" ]]; then
  exit 1
fi

printf '%s' "${!CONFIG_KEY}"
EOF
  )"
  local exit_code=$?
  set -e

  if [[ "$exit_code" -ne 0 ]]; then
    return 1
  fi

  printf '%s' "$value"
}

write_config_file() {
  local config_file="$1"
  local override_key="${2:-}"
  local override_value="${3:-}"
  local unset_key="${4:-}"
  local temp_file=""
  local key=""
  local value=""

  mkdir -p "$(dirname "$config_file")"
  temp_file="$(mktemp)"

  {
    cat <<'EOF'
# e2e-pr-assets configuration
# Environment variables override values in this file.
# Update values with `e2e-configure --set KEY VALUE`.
#
# Common keys:
# - GITHUB_BROWSER_PROFILE: path to a signed-in GitHub browser profile
# - E2E_GITHUB_AUTO_LOGIN: 1 to auto-open GitHub login when needed
# - E2E_GITHUB_AUTO_REMOVE_PROFILE: 1 to delete temporary auth profiles after upload
# - E2E_GITHUB_FORCE_REMOVE_PROFILE: 1 to allow deleting non-/tmp profiles
# - E2E_MEDIA_AUTO_CLEANUP: 1 to remove /tmp media artifacts after attach
# - E2E_VIDEO_TRIM_START_SECONDS: initial trim before MP4 conversion
# - E2E_VIDEO_AUTO_SCENE_TRIM: 1 to auto-extend trim past blank lead-in
# - E2E_VIDEO_SCENE_THRESHOLD: scene-detect sensitivity for auto-trim
# - E2E_VIDEO_SCENE_PREROLL_SECONDS: preserve a small buffer before first scene

EOF

    while IFS= read -r key; do
      value=""

      if [[ -n "$unset_key" && "$key" == "$unset_key" ]]; then
        continue
      fi

      if [[ -n "$override_key" && "$key" == "$override_key" ]]; then
        value="$override_value"
      elif value="$(config_value_for_key "$key" "$config_file")"; then
        :
      else
        continue
      fi

      printf '%s=%s\n' "$key" "$(e2e_format_config_value "$value")"
    done < <(e2e_supported_config_keys)
  } > "$temp_file"

  mv "$temp_file" "$config_file"
}

show_config() {
  local config_file="$1"

  if [[ ! -f "$config_file" ]]; then
    write_config_file "$config_file"
  fi

  cat "$config_file"
}

ACTION="show"
KEY=""
VALUE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --show)
      ACTION="show"
      shift
      ;;
    --path)
      ACTION="path"
      shift
      ;;
    --set)
      ACTION="set"
      KEY="${2:-}"
      VALUE="${3:-}"
      shift 3
      ;;
    --unset)
      ACTION="unset"
      KEY="${2:-}"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

CONFIG_FILE="$(e2e_config_file)"

case "$ACTION" in
  path)
    printf '%s\n' "$CONFIG_FILE"
    ;;
  show)
    show_config "$CONFIG_FILE"
    ;;
  set)
    if [[ -z "$KEY" || -z "$VALUE" ]]; then
      echo "Error: --set requires KEY and VALUE" >&2
      usage >&2
      exit 1
    fi

    if ! e2e_is_supported_config_key "$KEY"; then
      echo "Error: unsupported config key: $KEY" >&2
      exit 1
    fi

    write_config_file "$CONFIG_FILE" "$KEY" "$VALUE"
    show_config "$CONFIG_FILE"
    ;;
  unset)
    if [[ -z "$KEY" ]]; then
      echo "Error: --unset requires KEY" >&2
      usage >&2
      exit 1
    fi

    if ! e2e_is_supported_config_key "$KEY"; then
      echo "Error: unsupported config key: $KEY" >&2
      exit 1
    fi

    write_config_file "$CONFIG_FILE" "" "" "$KEY"
    show_config "$CONFIG_FILE"
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
