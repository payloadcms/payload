#!/usr/bin/env bash
# e2e-ensure-github-auth <pr_number> <owner/repo> [profile-dir] [--repo /path/to/repo] [--check-only]
# Verifies that the selected browser profile is already signed in to GitHub for
# the target PR page. If not signed in, it can proactively open the login flow
# before the rest of the evidence workflow starts.

set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -h "$source" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="${dir}/${source}"
  done
  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/../../.." && pwd)"

PR="${1:-}"
REPO="${2:-}"
POSITIONAL_PROFILE="${3:-}"
BROWSER_PROFILE="${GITHUB_BROWSER_PROFILE:-/tmp/github-upload-profile}"
CHECK_ONLY=false
AUTO_LOGIN_ON_UNSIGNED_PROFILE="${E2E_GITHUB_AUTO_LOGIN:-1}"

if [[ -n "$POSITIONAL_PROFILE" && "$POSITIONAL_PROFILE" != "--repo" && "$POSITIONAL_PROFILE" != "--check-only" ]]; then
  BROWSER_PROFILE="$POSITIONAL_PROFILE"
else
  POSITIONAL_PROFILE=""
fi

shift 2 || true

if [[ -n "$POSITIONAL_PROFILE" ]]; then
  shift || true
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      REPO_ROOT="${2:-}"
      shift 2
      ;;
    --check-only)
      CHECK_ONLY=true
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Usage: e2e-ensure-github-auth <pr_number> <owner/repo> [profile-dir] [--repo /path/to/repo] [--check-only]" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$PR" || -z "$REPO" ]]; then
  echo "Usage: e2e-ensure-github-auth <pr_number> <owner/repo> [profile-dir] [--repo /path/to/repo] [--check-only]" >&2
  exit 1
fi

check_sign_in() {
  pnpm --dir "$REPO_ROOT" exec node - "$PR" "$REPO" "$BROWSER_PROFILE" <<'NODE'
const { chromium } = require('@playwright/test')

const [, , pr, repo, browserProfile] = process.argv

;(async () => {
  const context = await chromium.launchPersistentContext(browserProfile, {
    headless: true,
    args: ['--profile-directory=Default'],
  })

  try {
    const page = await context.newPage()
    await page.goto(`https://github.com/${repo}/pull/${pr}`, {
      waitUntil: 'domcontentloaded',
      timeout: 60000,
    })
    await page.waitForLoadState('load', { timeout: 60000 }).catch(() => {})

    const isSignedIn = await page.evaluate(() => {
      const login = document.querySelector('meta[name="user-login"]')?.getAttribute('content')
      return Boolean(login) && !document.body.innerText.includes('Sign in to comment')
    })

    if (!isSignedIn) {
      console.error(
        `GitHub is not signed in for browser profile: ${browserProfile}. Sign in with that profile, or set GITHUB_BROWSER_PROFILE to a signed-in profile.`,
      )
      process.exit(1)
    }

    console.log(`GitHub is signed in for browser profile: ${browserProfile}`)
  } finally {
    await context.close().catch(() => {})
  }
})().catch((error) => {
  console.error(error instanceof Error ? error.message : String(error))
  process.exit(1)
})
NODE
}

set +e
check_output="$(check_sign_in 2>&1)"
check_exit_code=$?
set -e

if [[ "$check_exit_code" -eq 0 ]]; then
  printf '%s\n' "$check_output"
  exit 0
fi

echo "$check_output" >&2

if [[ "$CHECK_ONLY" == "true" || "$AUTO_LOGIN_ON_UNSIGNED_PROFILE" != "1" ]]; then
  exit "$check_exit_code"
fi

echo "Opening GitHub login flow up front for browser profile: $BROWSER_PROFILE" >&2
"${SCRIPT_DIR}/e2e-github-login-profile" "$BROWSER_PROFILE" --repo "$REPO_ROOT"

set +e
retry_output="$(check_sign_in 2>&1)"
retry_exit_code=$?
set -e

if [[ "$retry_exit_code" -ne 0 ]]; then
  echo "$retry_output" >&2
  exit "$retry_exit_code"
fi

printf '%s\n' "$retry_output"
