#!/usr/bin/env bash
# e2e-convert-video <label>
# Converts /tmp/payload-e2e-<label>.webm -> /tmp/payload-e2e-<label>.mp4
# If output exceeds 9.5MB, re-encodes with two-pass targeting 9MB to stay
# under GitHub's 10MB PR comment asset limit.

set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -h "$source" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="${dir}/${source}"
  done
  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"

# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../lib/config.sh"
e2e_load_config

LABEL="${1:-}"
if [[ -z "$LABEL" ]]; then
  echo "Usage: e2e-convert-video <label>  (e.g. before | after)" >&2
  exit 1
fi

INPUT="/tmp/payload-e2e-${LABEL}.webm"
OUTPUT="/tmp/payload-e2e-${LABEL}.mp4"
MAX_BYTES=9961472
TARGET_MB=9
TRIM_START_SECONDS="${E2E_VIDEO_TRIM_START_SECONDS:-1}"
AUTO_SCENE_TRIM="${E2E_VIDEO_AUTO_SCENE_TRIM:-1}"
SCENE_THRESHOLD="${E2E_VIDEO_SCENE_THRESHOLD:-0.003}"
SCENE_PREROLL_SECONDS="${E2E_VIDEO_SCENE_PREROLL_SECONDS:-0.05}"

if [[ ! -f "$INPUT" ]]; then
  echo "Error: $INPUT not found" >&2
  exit 1
fi

for bin in ffmpeg ffprobe bc; do
  if ! command -v "$bin" >/dev/null 2>&1; then
    echo "Error: required binary '$bin' is not installed" >&2
    exit 1
  fi
done

echo "Converting $INPUT -> $OUTPUT ..."

encode_with_videotoolbox() {
  ffmpeg -nostdin -i "$INPUT" -ss "$TRIM_START_SECONDS" -c:v h264_videotoolbox -b:v 3200k -pix_fmt yuv420p -movflags +faststart "$OUTPUT" -y -loglevel error
}

encode_with_libx264() {
  ffmpeg -nostdin -i "$INPUT" -ss "$TRIM_START_SECONDS" -c:v libx264 -preset fast -crf 18 -pix_fmt yuv420p -movflags +faststart "$OUTPUT" -y -loglevel error
}

detect_trim_start_seconds() {
  local detected_scene_output
  local detected_scene

  detected_scene_output="$(
    ffprobe -v error -f lavfi "movie=${INPUT},select=gt(scene\\,${SCENE_THRESHOLD})" \
      -show_entries frame=pts_time -of csv=p=0 2>/dev/null || true
  )"
  detected_scene="$(printf '%s\n' "$detected_scene_output" | sed -n '1p')"

  if [[ ! "$detected_scene" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    return 0
  fi

  if [[ "$(echo "$detected_scene > $TRIM_START_SECONDS" | bc -l)" != "1" ]]; then
    return 0
  fi

  local adjusted_trim
  adjusted_trim="$(echo "$detected_scene - $SCENE_PREROLL_SECONDS" | bc -l)"

  if [[ "$(echo "$adjusted_trim < 0" | bc -l)" == "1" ]]; then
    adjusted_trim="0"
  fi

  TRIM_START_SECONDS="$adjusted_trim"
}

if [[ "$AUTO_SCENE_TRIM" == "1" ]]; then
  detect_trim_start_seconds
fi

echo "Using trim start: ${TRIM_START_SECONDS}s"

if ffmpeg -hide_banner -encoders 2>/dev/null | grep -q 'h264_videotoolbox'; then
  if ! encode_with_videotoolbox; then
    echo "h264_videotoolbox failed; retrying conversion with libx264..."
    rm -f "$OUTPUT"
    encode_with_libx264
  fi
else
  encode_with_libx264
fi

if [[ ! -s "$OUTPUT" ]]; then
  echo "Error: conversion did not create $OUTPUT" >&2
  exit 1
fi

if ! ffprobe -v error -select_streams v:0 -show_entries stream=codec_name -of csv=p=0 "$OUTPUT" | grep -q '^h264$'; then
  echo "Error: $OUTPUT is not H.264 MP4; GitHub may not render it inline" >&2
  exit 1
fi

SIZE=$(stat -f%z "$OUTPUT" 2>/dev/null || stat -c%s "$OUTPUT")

if [[ "$SIZE" -gt "$MAX_BYTES" ]]; then
  SIZE_MB=$(( SIZE / 1024 / 1024 ))
  echo "Output is ${SIZE_MB}MB, exceeds limit — re-encoding to ~${TARGET_MB}MB with two-pass..."

  DURATION=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$OUTPUT")
  BITRATE=$(echo "scale=0; $TARGET_MB * 8192 / $DURATION" | bc)

  ffmpeg -i "$INPUT" -ss "$TRIM_START_SECONDS" -c:v libx264 -b:v "${BITRATE}k" -pix_fmt yuv420p -pass 1 -f mp4 /dev/null -y -loglevel error
  ffmpeg -i "$INPUT" -ss "$TRIM_START_SECONDS" -c:v libx264 -b:v "${BITRATE}k" -pix_fmt yuv420p -pass 2 -movflags +faststart "$OUTPUT" -y -loglevel error
  rm -f ffmpeg2pass-0.log ffmpeg2pass-0.log.mbtree

  FINAL_SIZE=$(stat -f%z "$OUTPUT" 2>/dev/null || stat -c%s "$OUTPUT")
  echo "Re-encoded to $(( FINAL_SIZE / 1024 / 1024 ))MB"
fi

echo "$OUTPUT"
