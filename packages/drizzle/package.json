{
  "name": "@payloadcms/drizzle",
  "version": "4.0.0-beta.0",
  "description": "A library of shared functions used by different payload database adapters",
  "homepage": "https://payloadcms.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/payloadcms/payload.git",
    "directory": "packages/drizzle"
  },
  "license": "MIT",
  "author": "Payload <dev@payloadcms.com> (https://payloadcms.com)",
  "maintainers": [
    {
      "name": "Payload",
      "email": "info@payloadcms.com",
      "url": "https://payloadcms.com"
    }
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./mssql": {
      "import": "./src/exports/mssql.ts",
      "types": "./src/exports/mssql.ts",
      "default": "./src/exports/mssql.ts"
    },
    "./postgres": {
      "import": "./src/exports/postgres.ts",
      "types": "./src/exports/postgres.ts",
      "default": "./src/exports/postgres.ts"
    },
    "./sqlite": {
      "import": "./src/exports/sqlite.ts",
      "types": "./src/exports/sqlite.ts",
      "default": "./src/exports/sqlite.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "mock.js"
  ],
  "scripts": {
    "build": "pnpm build:swc && pnpm build:types",
    "build:debug": "pnpm build",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "clean": "rimraf -g {dist,*.tsbuildinfo}",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "console-table-printer": "2.15.0",
    "dequal": "2.0.3",
    "drizzle-orm": "1.0.0-rc.4",
    "prompts": "2.4.2",
    "to-snake-case": "1.0.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@libsql/client": "0.14.0",
    "@payloadcms/eslint-config": "workspace:*",
    "@types/mssql": "9.1.7",
    "@types/pg": "8.20.0",
    "@types/to-snake-case": "1.0.0",
    "mssql": "11.0.1",
    "payload": "workspace:*"
  },
  "peerDependencies": {
    "payload": "workspace:*"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./mssql": {
        "import": "./dist/exports/mssql.js",
        "types": "./dist/exports/mssql.d.ts",
        "default": "./dist/exports/mssql.js"
      },
      "./postgres": {
        "import": "./dist/exports/postgres.js",
        "types": "./dist/exports/postgres.d.ts",
        "default": "./dist/exports/postgres.js"
      },
      "./sqlite": {
        "import": "./dist/exports/sqlite.js",
        "types": "./dist/exports/sqlite.d.ts",
        "default": "./dist/exports/sqlite.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  }
}
