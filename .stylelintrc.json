{
  "plugins": [
    "./.stylelint/no-tilde-imports.js",
    "./.stylelint/no-max-width-media-query.js",
    "./.stylelint/no-non-standard-breakpoints.js"
  ],
  "rules": {
    "plugin/no-max-width-media-query": true,
    "plugin/no-non-standard-breakpoints": true
  },
  "overrides": [
    {
      "files": ["**/*.scss"],
      "customSyntax": "postcss-scss",
      "rules": {
        "plugin/no-tilde-imports": true
      }
    }
  ]
}
