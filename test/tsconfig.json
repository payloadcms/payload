{
  "compilerOptions": {
    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      },
      {
        "name": "@payloadcms/typescript-plugin"
      }
    ],
    "paths": {
      "@payload-config": ["./tags/config.ts"]
    }
  },
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "eslint.config.js",
    "dist/**/*.js",
    "**/dist/**/*.js"
  ],
  // Each test suite (for example ./fields) has its own tsconfig that lists only its own files.
  // This root config only covers the top-level files and the few folders that don't have their
  // own tsconfig. That way, opening one test file doesn't load every test in the whole folder.
  "include": [
    "./*.ts",
    "./*.tsx",
    "./__helpers/**/*.ts",
    "./__helpers/**/*.tsx",
    "./app/**/*.ts",
    "./app/**/*.tsx",
    "./evals/**/*.ts",
    "./evals/**/*.tsx"
  ],
  "references": []
}
