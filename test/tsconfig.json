{
  "compilerOptions": {
    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      },
      {
        "name": "@payloadcms/typescript-plugin"
      }
    ],
    "paths": {
      "@payload-config": ["./tags/config.ts"],
      "__helpers/*": ["./__helpers/*"]
    }
  },
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "eslint.config.js",
    "dist/**/*.js",
    "**/dist/**/*.js"
  ],
  // Each test suite (for example ./fields) has its own tsconfig listing only its own files, so
  // opening one test file does not pull the whole test/ folder into the program. This root config
  // is only the fallback for top-level files and the folders without their own tsconfig. Give a
  // new suite its own tsconfig rather than adding it here.
  "include": [
    "./*.ts",
    "./*.tsx",
    "./__helpers/**/*.ts",
    "./__helpers/**/*.tsx",
    "./app/**/*.ts",
    "./app/**/*.tsx",
    "./evals/**/*.ts",
    "./evals/**/*.tsx"
  ],
  "references": []
}
