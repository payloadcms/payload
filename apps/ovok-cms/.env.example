# Postgres connection string. `DATABASE_URL` is honoured as a fallback for
# compatibility with the upstream template.
DATABASE_URI=postgres://payload:payload@localhost:5432/payload

# Encrypts Payload's own cookies/tokens. 32+ random characters.
#   openssl rand -base64 32
PAYLOAD_SECRET=replace-with-random-secret

# URL the Ovok proxy will hit, e.g. http://ovok-cms.cluster.local inside
# the cluster. Payload needs to know its own externally-resolvable URL.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Shared secret with the Ovok backend. Must be identical to Ovok's
# PAYLOAD_INTERNAL_API_KEY. Every proxied request carries this in the
# x-ovok-internal-key header; the custom auth strategy rejects anything
# without it.
#   openssl rand -base64 32
PAYLOAD_INTERNAL_API_KEY=replace-with-shared-secret
